#include<iostream>
#include<vector>
using namespace std;
int f(vector<int>&arr,int i,int j){
    int maxi=-1e9;
    int right=-1;
    int mini=1e9;
    int left=-1;

    for(int a=i;a<=j;a++){
        int ele=arr[a];
        if(ele<maxi){
            right=a;

        }
        maxi=max(maxi,ele);



    }
    for(int a=j;a>=i;a--){
        int ele=arr[a];
        if(ele>mini){
            left=a;

        }
        mini=min(mini,ele);

    }
    if(right==-1){
        return 0;
    }
    return right-left+1;


}
int main(){
    vector<int>arr;
    int n;
    cin>>n;
    int k;
    cin>>k;

    for(int i=0;i<n;i++){
        int ele;
        cin>>ele;
        arr.push_back(ele);

    }
    vector<int>ans;
    
    for (int i = 0; i + k - 1 < n; i++) {
        int j = i + k - 1;
        ans.push_back(f(arr, i, j));
    }
    for(int i=0;i<ans.size();i++){
        cout<<ans[i]<<endl;
    }




    return 0;

}
