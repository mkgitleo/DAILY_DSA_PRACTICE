class Solution {
public:

    // BFS function to detect cycle starting from (sr, sc)
    bool bfs(vector<vector<char>>& input, int r, int c, int sr, int sc,
             vector<vector<int>>& vis) {

        // Direction vectors → Up, Right, Down, Left
        int drow[] = {-1, 0, 1, 0};
        int dcol[] = {0, 1, 0, -1};

        // Queue stores:
        // {{current_row, current_col}, {parent_row, parent_col}}
        queue<pair<pair<int, int>, pair<int, int>>> q;

        // Push starting cell with no parent (-1, -1)
        q.push({{sr, sc}, {-1, -1}});

        // Mark starting cell as visited
        vis[sr][sc] = 1;

        // BFS traversal starts
        while (q.size()) {

            // Get current node
            int crow = q.front().first.first;
            int ccol = q.front().first.second;

            // Get parent of current node
            int prow = q.front().second.first;
            int pcol = q.front().second.second;

            // Character at current cell
            char cchar = input[crow][ccol];

            // Remove from queue
            q.pop();

            // Explore all 4 directions
            for (int i = 0; i < 4; i++) {

                int nrow = crow + drow[i];
                int ncol = ccol + dcol[i];

                // Check boundaries (avoid out-of-bounds access)
                if (nrow >= 0 && nrow < r && ncol >= 0 && ncol < c) {

                    char nchar = input[nrow][ncol];

                    // Only move if same character (important condition)
                    if (cchar == nchar) {

                        // CASE 1: Not visited → continue BFS
                        if (!vis[nrow][ncol]) {
                            vis[nrow][ncol] = 1;

                            // Push neighbor with current as parent
                            q.push({{nrow, ncol}, {crow, ccol}});
                        }

                        // CASE 2: Already visited
                        // If it's NOT the parent → cycle detected
                        else if (nrow != prow || ncol != pcol) {
                            return true;  // ✅ cycle found
                        }

                        // CASE 3: If it is parent → ignore (normal BFS behavior)
                    }
                }
            }
        }

        // No cycle found in this component
        return false;
    }

    // Main function
    bool containsCycle(vector<vector<char>>& input) {

        int r = input.size();
        int c = input[0].size();

        // Visited matrix to track visited cells
        vector<vector<int>> vis(r, vector<int>(c, 0));

        // Traverse every cell
        for (int i = 0; i < r; i++) {
            for (int j = 0; j < c; j++) {

                // If not visited, start BFS
                if (!vis[i][j]) {

                    // If cycle found in any component → return true
                    if (bfs(input, r, c, i, j, vis)) {
                        return true;
                    }
                }
            }
        }

        // No cycle found anywhere
        return false;
    }
};
