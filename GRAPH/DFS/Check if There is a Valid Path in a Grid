class Solution {
public:
unordered_map<int,vector<vector<int>>>m1={
    {1,{{0,-1},{0,1}}},
    {2,{{-1,0},{1,0}}},
    {3,{{0,-1},{1,0}}},
    {4,{{0,1},{1,0}}},
    {5,{{0,-1},{-1,0}}},
    {6,{{-1,0},{0,1}}},




};
bool dfs(vector<vector<int>>& input,vector<vector<int>>&vis,int crow,int ccol){
   int r=input.size();
   int c=input[0].size();
   if(crow==r-1&&ccol==c-1){
    return true;

   }
   vis[crow][ccol]=1;
   int ele=input[crow][ccol];   //3
   vector<vector<int>>allowed=m1[ele];
   for(int i=0;i<2;i++){     //{{0,-1},{1,0}}
      
        int drow=allowed[i][0];
        int dcol=allowed[i][1];
        int nrow=crow+drow;
        int ncol=ccol+dcol;
        if(nrow<0||nrow>=r||ncol<0||ncol>=c||vis[nrow][ncol]){
            continue;
        }
        int nele=input[nrow][ncol];

        vector<vector<int>>temp=m1[nele];
        for(int j=0;j<2;j++){
             int drow=temp[j][0];
             int dcol=temp[j][1];
             int backrow=nrow+drow;
             int backcol=ncol+dcol;
             if(backrow==crow&&backcol==ccol){
                if(dfs(input,vis,nrow,ncol)){
                    return true;

                }
             }

        }





      

   }
   return false;




}

    bool hasValidPath(vector<vector<int>>& input) {
        int r=input.size();
        int c=input[0].size();
        vector<vector<int>>vis(r,vector<int>(c,0));
        return dfs(input,vis,0,0);


        
    }
};
